# ============================================
# LiteLLM 配置
# ============================================

# 主密钥 - 用于管理员操作 (创建用户、API Keys等)
# 请使用强密钥，例如: sk-$(openssl rand -hex 32)
LITELLM_MASTER_KEY=sk-your-master-key-here

# ============================================
# 数据库配置
# ============================================

# PostgreSQL 连接URL
DATABASE_URL=postgresql://litellm:litellm_password@postgres:5432/litellm

# PostgreSQL 独立配置
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm_password
POSTGRES_DB=litellm

# ============================================
# Azure OpenAI 配置
# ============================================

# 主要 Azure OpenAI 端点
AZURE_API_BASE=https://your-resource-name.openai.azure.com/
AZURE_API_KEY=your-azure-openai-api-key
AZURE_API_VERSION=2024-10-01-preview

# 备用 Azure OpenAI 端点 (可选)
AZURE_API_BASE_BACKUP=https://your-backup-resource.openai.azure.com/
AZURE_API_KEY_BACKUP=your-backup-api-key

# ============================================
# 可选配置
# ============================================

# Langfuse 配置 (用于监控和追踪)
# LANGFUSE_PUBLIC_KEY=pk-your-public-key
# LANGFUSE_SECRET_KEY=sk-your-secret-key
# LANGFUSE_HOST=https://cloud.langfuse.com

# Redis 配置 (用于缓存)
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
